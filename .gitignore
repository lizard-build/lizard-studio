# Legacy in-repo host artifacts (install.sh now generates these in ~/.lizard-studio/host).
# Kept ignored so older checkouts don't accidentally commit them.
src/host/host-config.json
src/host/launch.sh
src/host/host.log
src/host/shell-env.json
# Generated at runtime by claude-host.mjs (quarantine-free spawn shim).
src/host/spawn-shim.mjs
# Per-run spawn-shim auth token (0600); written by claude-host.mjs.
src/host/.spawn-token
# Per-session mcp-config (0600, carries the bridge token); written by claude-host.mjs.
src/host/.mcp-config-*.json

.DS_Store

# Chrome Web Store upload packages built by scripts/build-zip.sh
dist/
# Local npm pack artifact of the host
*.tgz
