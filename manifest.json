{
  "manifest_version": 3,
  "name": "Lizard Studio — Claude Code Side Panel",
  "version": "1.0.1",
  "description": "An AI coding agent that lives next to the page you're building.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": ["activeTab", "storage", "clipboardWrite", "sidePanel", "nativeMessaging", "declarativeNetRequest", "debugger", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Lizard Studio — toggle toolbar (set a shortcut in chrome://extensions/shortcuts)"
  },
  "side_panel": {
    "default_path": "src/panel/panel.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "toggle-toolbar": {
      "description": "Toggle the Lizard Studio toolbar"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": [
        "src/core.js",
        "src/tools/distance.js",
        "src/tools/selector.js",
        "src/tools/annotate.js",
        "src/tools/picker.js",
        "src/tools/rulers.js",
        "src/tools/guides.js",
        "src/tools/grid.js",
        "src/tools/responsive.js",
        "src/toolbar.js",
        "src/main.js"
      ]
    }
  ]
}
